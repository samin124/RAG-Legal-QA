# Legal Document Q&A Assistant - Environment Variables
# Copy this file to .env and replace with your actual API keys

# =============================================================================
# REQUIRED API KEYS
# =============================================================================

# Groq API Key (Required for LLM - Fast inference)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Google API Key (Required for Gemini Embeddings)
# Get yours at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# LlamaCloud API Key (Required for LlamaParse document parsing with OCR)
# Get yours at: https://cloud.llamaindex.ai/
LLAMA_CLOUD_API_KEY=llx_your_llamacloud_api_key_here

# Tavily API Key (Required for web search fallback)
# Get yours at: https://tavily.com/ (free tier available)
TAVILY_API_KEY=tvly_your_tavily_api_key_here

# =============================================================================
# OPTIONAL API KEYS
# =============================================================================

# OpenAI API Key (Optional - fallback LLM if Groq fails)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-demo-replace-with-your-key

# Cohere API Key (Optional - for reranking, improves retrieval quality)
# Get yours at: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_api_key_here

# =============================================================================
# QDRANT CONFIGURATION (Optional - defaults to in-memory)
# =============================================================================

# Qdrant URL (Optional - for remote Qdrant instance)
# Leave empty for in-memory storage (default)
# QDRANT_URL=http://localhost:6333

# Qdrant API Key (Optional - for Qdrant Cloud)
# QDRANT_API_KEY=your-qdrant-api-key

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Enable OCR for scanned documents (true/false)
ENABLE_OCR=true

# Default LLM model (Groq)
DEFAULT_LLM_MODEL=llama-3.3-70b-versatile

# Use Groq (true) or OpenAI (false)
USE_GROQ=true

# Embedding model (Google Gemini)
EMBEDDING_MODEL=models/gemini-embedding-001

# Chunk size for document splitting
CHUNK_SIZE=1000

# Chunk overlap
CHUNK_OVERLAP=200
